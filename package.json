{
  "name": "the-mango-theme",
  "displayName": "The Mango Theme",
  "description": "A clean, readable dark theme for VS Code — one JSON file, easy to customize.",
  "version": "1.0.1",
  "publisher": "sanjeevkse",
  "license": "MIT",
  "galleryBanner": {
    "color": "#282C34",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.87.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "mango",
    "theme",
    "dark",
    "color-theme",
    "readable"
  ],
  "icon": "icon.png",
  "contributes": {
    "configurationDefaults": {
      "[Mango Dark]": {
        "editor.fontFamily": "Menlo, Consolas, 'DejaVu Sans Mono', monospace",
        "editor.fontSize": 14,
        "editor.lineHeight": 1.5,
        "editor.fontLigatures": false,
        "editor.fontWeight": "normal",
        "editor.semanticHighlighting.enabled": false,
        "editor.minimap.enabled": false,
        "editor.renderLineHighlight": "line",
        "editor.renderWhitespace": "none",
        "editor.renderControlCharacters": false,
        "editor.scrollBeyondLastLine": false,
        "editor.rulers": [
          80
        ],
        "editor.wordWrap": "off",
        "editor.cursorBlinking": "solid",
        "editor.cursorStyle": "line",
        "editor.cursorWidth": 2,
        "editor.smoothScrolling": true,
        "editor.bracketPairColorization.enabled": false,
        "editor.matchBrackets": "always",
        "editor.guides.indentation": true,
        "editor.guides.highlightActiveIndentation": false,
        "editor.stickyScroll.enabled": false,
        "editor.occurrencesHighlight": "off",
        "editor.showFoldingControls": "mouseover",
        "editor.glyphMargin": false,
        "editor.padding.top": 0,
        "breadcrumbs.enabled": false,
        "explorer.openEditors.visible": 0,
        "explorer.compactFolders": false,
        "workbench.activityBar.location": "hidden",
        "workbench.editor.showTabs": "multiple",
        "workbench.editor.tabSizing": "fit",
        "workbench.editor.enablePreview": false,
        "workbench.editor.highlightModifiedTabs": true,
        "workbench.tree.indent": 16,
        "workbench.tree.renderIndentGuides": "always",
        "workbench.fontAliasing": "antialiased",
        "workbench.layoutControl.enabled": false,
        "window.commandCenter": false,
        "terminal.integrated.fontFamily": "Menlo, Consolas, 'DejaVu Sans Mono', monospace",
        "terminal.integrated.fontSize": 14,
        "terminal.integrated.lineHeight": 1.5
      }
    },
    "themes": [
      {
        "label": "Mango Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/MangoDark-color-theme.json"
      }
    ]
  },
  "bugs": {
    "url": "https://github.com/sanjeevkse/the-mango-theme/issues",
    "email": "sanjeevkse@gmail.com"
  },
  "homepage": "https://github.com/sanjeevkse/the-mango-theme",
  "repository": {
    "type": "git",
    "url": "https://github.com/sanjeevkse/the-mango-theme"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/sanjeevkse"
  }
}